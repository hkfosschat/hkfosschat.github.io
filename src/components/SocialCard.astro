---
interface Props {
	platform: 'mastodon' | 'threads';
	author: string;
	content: string;
	date: string;
	url: string;
}

const { platform, author, content, date, url } = Astro.props;
---

<div class="bg-gray-100 border border-gray-200 rounded-xl p-6 flex flex-col gap-4 shadow-sm hover:shadow-md transition-shadow">
	<div class="flex justify-between items-center">
		<div class="font-semibold text-gray-900">{author}</div>
		<div class="text-sm text-gray-600 capitalize bg-gray-200 px-2 py-1 rounded">{platform}</div>
	</div>
	<div class="text-gray-800 whitespace-pre-line" set:html={content}></div>
	<div class="text-sm text-gray-500 mt-auto pt-4 flex justify-between items-center border-t border-gray-200">
		<time datetime={date}>{new Date(date).toLocaleDateString()}</time>
		<a href={url} target="_blank" rel="noopener noreferrer" class="text-[#065fd4] hover:text-blue-800 transition-colors">View Post &rarr;</a>
	</div>
</div>
