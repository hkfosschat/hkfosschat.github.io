---
import Layout from '../layouts/Layout.astro';
import SocialCard from '../components/SocialCard.astro';
import { fetchMastodonPost, fetchThreadsPost } from '../utils/api.js';

let mastodonPost = null;
try {
	const mastodonData = await fetchMastodonPost('https://fosstodon.org/@hkfosschat');
	if (mastodonData && mastodonData.length > 0) {
		const post = mastodonData[0];
		mastodonPost = {
			platform: 'mastodon',
			author: post.account.display_name || post.account.username,
			content: post.content,
			date: post.created_at,
			url: post.url
		};
	}
} catch (e) {
	console.error('Failed to fetch Mastodon post:', e);
}

let threadsPost = null;
try {
	const threadsData = await fetchThreadsPost();
	if (threadsData && threadsData.data && threadsData.data.length > 0) {
		const post = threadsData.data[0];
		threadsPost = {
			platform: 'threads',
			author: 'HKFOSSChat', // Threads API often doesn't include user details in basic post fetch without extra scopes
			content: post.text || 'View post on Threads',
			date: post.timestamp,
			url: `https://www.threads.net/@hkfosschat/post/${post.id}`
		};
	}
} catch (e) {
	console.error('Failed to fetch Threads post:', e);
}
---

<Layout title="我哋講開">
	<header class="mb-12">
		<img src="/images/logo.webp" alt="我哋講開 Logo" class="h-24 w-24 md:h-32 md:w-32 rounded-full object-cover shadow-sm mb-6" />
		<h1 class="text-4xl md:text-6xl font-bold tracking-tight text-gray-900 mb-4">
			我哋講開
		</h1>
		<p class="text-lg text-gray-600 mb-6">
			用廣東話，由淺入深，暢談開源科技新聞，淺談技術細節
		</p>
		<div class="flex gap-4">
			<a href="https://www.youtube.com/@hkfosschat" target="_blank" rel="noopener noreferrer" class="text-[#065fd4] hover:text-blue-800 transition-colors">YouTube</a>
			<a href="https://fosstodon.org/@hkfosschat" target="_blank" rel="noopener noreferrer" class="text-[#065fd4] hover:text-blue-800 transition-colors">Mastodon</a>
			<a href="https://www.threads.net/@hkfosschat" target="_blank" rel="noopener noreferrer" class="text-[#065fd4] hover:text-blue-800 transition-colors">Threads</a>
			<a href="/videos" class="text-[#065fd4] hover:text-blue-800 transition-colors ml-auto">All Videos &rarr;</a>
		</div>
	</header>

	<main class="grid gap-12">
		<section class="bg-gray-100 border border-gray-200 rounded-xl p-6 md:p-8">
			<h2 class="text-2xl font-semibold mb-4 text-gray-900">Latest Episodes</h2>
			<div class="text-gray-600">
				Coming soon...
			</div>
		</section>

		<section class="grid md:grid-cols-2 gap-8">
			<div>
				<h2 class="text-2xl font-semibold mb-4 text-gray-900 flex items-center gap-2">
					<svg class="h-6 w-auto shrink-0" viewBox="0 0 448 512" fill="currentColor"><path d="M433 179.11c0-97.2-63.71-125.7-63.71-125.7-62.52-28.7-228.56-28.4-290.48 0 0 0-63.72 28.5-63.72 125.7 0 115.7-6.6 259.4 105.63 289.1 40.51 10.7 75.32 13 103.33 11.4 50.81-2.8 79.32-18.1 79.32-18.1l-1.7-36.9s-36.31 11.4-77.12 10.1c-40.41-1.4-83-4.4-89.63-54a102.54 102.54 0 0 1-.9-13.9c85.63 20.9 158.65 9.1 178.75 6.7 56.12-6.7 105-41.3 111.23-72.9 9.8-49.8 9-121.5 9-121.5zm-75.12 125.2h-46.63v-114.2c0-49.7-64-51.6-64 6.9v62.5h-46.33V197c0-58.5-64-56.6-64-6.9v114.2H90.19c0-122.1-5.2-147.9 18.41-175 25.9-28.9 79.82-30.8 103.83 6.1l11.6 19.5 11.6-19.5c24.11-37.1 78.12-34.8 103.83-6.1 23.71 27.3 18.4 53 18.4 175z"/></svg>
					Mastodon
				</h2>
				{mastodonPost ? (
					<SocialCard {...mastodonPost} />
				) : (
					<div class="bg-gray-100 border border-gray-200 rounded-xl p-6 text-gray-500 italic">
						Unable to load recent post. Check back later!
					</div>
				)}
			</div>
			
			<div>
				<h2 class="text-2xl font-semibold mb-4 text-gray-900 flex items-center gap-2">
					<svg class="h-6 w-6 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M12.186 24h-.007c-3.581-.024-6.334-1.205-8.184-3.509C2.35 18.44 1.5 15.586 1.472 12.01v-.017c.03-3.579.879-6.43 2.525-8.482C5.845 1.205 8.6.024 12.18 0h.014c2.746.02 5.043.725 6.826 2.098 1.677 1.29 2.858 3.13 3.509 5.467l-2.04.569c-1.104-3.96-3.898-5.984-8.304-6.015-2.91.022-5.11.936-6.54 2.717C4.307 6.504 3.616 8.914 3.589 12c.027 3.086.718 5.496 2.057 7.164 1.43 1.783 3.631 2.698 6.54 2.717 2.623-.02 4.358-.631 5.8-2.045 1.647-1.613 1.618-3.593 1.09-4.798-.31-.71-.873-1.3-1.634-1.75-.192 1.352-.622 2.446-1.284 3.272-.886 1.102-2.14 1.704-3.73 1.79-1.202.065-2.361-.218-3.259-.801-1.063-.689-1.685-1.74-1.752-2.964-.065-1.19.408-2.285 1.33-3.082.88-.76 2.119-1.207 3.583-1.291a13.853 13.853 0 0 1 3.02.142c-.126-.742-.375-1.332-.75-1.757-.513-.586-1.308-.883-2.359-.89h-.029c-.844 0-1.992.232-2.721 1.32L7.734 7.847c.98-1.454 2.568-2.256 4.478-2.256h.044c3.194.02 5.097 1.975 5.287 5.388.108.046.216.094.321.142 1.49.7 2.58 1.761 3.154 3.07.797 1.82.871 4.79-1.548 7.158-1.85 1.81-4.094 2.628-7.277 2.65Zm1.003-11.69c-.242 0-.487.007-.739.021-1.836.103-2.98.946-2.916 2.143.067 1.256 1.452 1.839 2.784 1.767 1.224-.065 2.818-.543 3.086-3.71a10.5 10.5 0 0 0-2.215-.221z"/></svg>
					Threads
				</h2>
				{threadsPost ? (
					<SocialCard {...threadsPost} />
				) : (
					<div class="bg-gray-100 border border-gray-200 rounded-xl p-6 text-gray-500 italic">
						Unable to load recent post. Check back later!
					</div>
				)}
			</div>
		</section>
	</main>
</Layout>
