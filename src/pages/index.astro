---
import Layout from '../layouts/Layout.astro';
import SocialCard from '../components/SocialCard.astro';
import { fetchMastodonPost, fetchThreadsPost } from '../utils/api.js';

let mastodonPost = null;
try {
	const mastodonData = await fetchMastodonPost('https://fosstodon.org/@hkfosschat');
	if (mastodonData && mastodonData.length > 0) {
		const post = mastodonData[0];
		mastodonPost = {
			platform: 'mastodon',
			author: post.account.display_name || post.account.username,
			content: post.content,
			date: post.created_at,
			url: post.url
		};
	}
} catch (e) {
	console.error('Failed to fetch Mastodon post:', e);
}

let threadsPost = null;
try {
	const threadsData = await fetchThreadsPost();
	if (threadsData && threadsData.data && threadsData.data.length > 0) {
		const post = threadsData.data[0];
		threadsPost = {
			platform: 'threads',
			author: 'HKFOSSChat', // Threads API often doesn't include user details in basic post fetch without extra scopes
			content: post.text || 'View post on Threads',
			date: post.timestamp,
			url: `https://www.threads.net/@hkfosschat/post/${post.id}`
		};
	}
} catch (e) {
	console.error('Failed to fetch Threads post:', e);
}
---

<Layout title="我哋講開">
	<header class="mb-12">
		<img src="/images/logo.webp" alt="我哋講開 Logo" class="h-24 md:h-32 mb-6" />
		<h1 class="text-4xl md:text-6xl font-bold tracking-tight text-white mb-4">
			我哋講開
		</h1>
		<p class="text-lg text-slate-300 mb-6">
			用廣東話，由淺入深，暢談開源科技新聞，淺談技術細節
		</p>
		<div class="flex gap-4">
			<a href="https://www.youtube.com/@hkfosschat" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-white transition-colors">YouTube</a>
			<a href="https://fosstodon.org/@hkfosschat" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-white transition-colors">Mastodon</a>
			<a href="https://www.threads.net/@hkfosschat" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-white transition-colors">Threads</a>
			<a href="/videos" class="text-blue-400 hover:text-blue-300 transition-colors ml-auto">All Videos &rarr;</a>
		</div>
	</header>

	<main class="grid gap-12">
		<section class="bg-slate-900 border border-slate-800 rounded-xl p-6 md:p-8">
			<h2 class="text-2xl font-semibold mb-4 text-white">Latest Episodes</h2>
			<div class="text-slate-400">
				Coming soon...
			</div>
		</section>

		<section class="grid md:grid-cols-2 gap-8">
			<div>
				<h2 class="text-2xl font-semibold mb-4 text-white">Recent on Mastodon</h2>
				{mastodonPost ? (
					<SocialCard {...mastodonPost} />
				) : (
					<div class="bg-slate-900 border border-slate-800 rounded-xl p-6 text-slate-500 italic">
						Unable to load recent post. Check back later!
					</div>
				)}
			</div>
			
			<div>
				<h2 class="text-2xl font-semibold mb-4 text-white">Recent on Threads</h2>
				{threadsPost ? (
					<SocialCard {...threadsPost} />
				) : (
					<div class="bg-slate-900 border border-slate-800 rounded-xl p-6 text-slate-500 italic">
						Unable to load recent post. Check back later!
					</div>
				)}
			</div>
		</section>
	</main>
</Layout>
