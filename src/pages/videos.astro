---
import Layout from '../layouts/Layout.astro';
import VideoGrid from '../components/VideoGrid.astro';
import { fetchYouTubeVideos } from '../utils/api.js';

let videos = [];
try {
	const channelId = import.meta.env.YOUTUBE_CHANNEL_ID || 'UC_YOURCHANNEL_PLACEHOLDER';
	const youtubeData = await fetchYouTubeVideos(channelId);
	if (youtubeData && youtubeData.items) {
		videos = youtubeData.items.map((item: any) => ({
			id: item.contentDetails.videoId,
			title: item.snippet.title,
			thumbnail: item.snippet.thumbnails?.high?.url || item.snippet.thumbnails?.default?.url,
			url: `https://youtube.com/watch?v=${item.contentDetails.videoId}`
		}));
	}
} catch (e) {
	console.error('Failed to fetch YouTube videos:', e);
}
---

<Layout title="Videos | 我哋講開">
	<header class="mb-12">
		<a href="/" class="text-[#065fd4] hover:text-blue-800 transition-colors inline-block mb-4">&larr; 回到主頁</a>
		<img src="/images/logo.webp" alt="我哋講開 Logo" class="h-16 w-16 md:h-20 md:w-20 rounded-full object-cover shadow-sm mb-4" />
		<h1 class="text-4xl md:text-5xl font-bold tracking-tight text-gray-900 mb-4">
			歷來影片
		</h1>
		<p class="text-lg text-gray-600">
			點擊並在 YouTube 上觀看我們的影片
		</p>
	</header>

	<main>
		{videos.length > 0 ? (
			<VideoGrid videos={videos} />
		) : (
			<div class="bg-gray-100 border border-gray-200 rounded-xl p-8 text-center">
				<p class="text-gray-600">沒有找到影片，請確定生成的程序有正確設定好對應的 API key。</p>
			</div>
		)}
	</main>
</Layout>
